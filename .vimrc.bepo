" configuration du copié sur le ç car y est sur la touche composé ^

noremap ç y
noremap ^ y

" configuration des nombres

noremap $ `
noremap " 1
noremap « 2
noremap » 3
noremap ( 4
noremap ) 5
noremap @ 6
noremap + 7
noremap - 8
noremap / 9
noremap * 0
noremap = -
noremap % =
noremap # ~
noremap 1 !
noremap 2 @
noremap 3 #
noremap 4 $
noremap 5 %
noremap 6 ^
noremap 7 &
noremap 8 *
noremap 9 (
noremap 0 )
noremap ° _
noremap ` +

" colorise les nbsp
highlight NbSp ctermbg=lightgray guibg=lightred

" Faire apparaître les insécable avec un autre caractère
set listchars=nbsp:¤,tab:>-,trail:¤,extends:>,precedes:<
set list

" NERDTree for bépo
let NERDTreeMapOpenInTab='h'
let NERDTreeMapOpenInTabSilent='H'
let NERDTreeMapOpenVSplit='<C-v>'
let NERDTreeMapJumpFirstChild='S'
let NERDTreeMapJumpLastChild='T'
let NERDTreeMapJumpNextSibling='<C-T>'
let NERDTreeMapJumpPrevSibling='<C-S>'
let NERDTreeMapJumpParent='j'
let NERDTreeMapRefresh='o'
let NERDTreeMapRefresh='O'
let NERDTreeMapOpenInTab='è'
let NERDTreeMapOpenInTabSilent='È'
let NERDTreeMapActivateNode='l'

" map leader
let mapleader="w"

" map ctrl
noremap <C-k> <C-b>
noremap <C-e> <C-f>
noremap <C-i> <C-d>
noremap <C-v> <C-u>
noremap <C-o> <C-r>
noremap <C-à-u> <C-w-s>

" map tab
noremap è' :tabnew<CR>
noremap èr :tabnext<CR>
noremap èc :tabprev<CR>
noremap èt :tabfirst<CR>
noremap ès :tablast<CR>

" map tampon
noremap êr :bn<cr>
noremap êc :bp<cr>
noremap êi :bd<cr>

