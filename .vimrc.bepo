noremap \ \
noremap c h
noremap t j
noremap s k
noremap r l
noremap n ;
noremap nx mc
noremap m '
noremap ê <
noremap à z
noremap àà zz
noremap y x
noremap x c
noremap xx cc
noremap xà cw
noremap xdà ciw
noremap . v
noremap k b
noremap ' n
noremap q m
noremap g ,
noremap , g
noremap ,, gg
